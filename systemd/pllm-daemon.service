[Unit]
Description=PLLM foreground-aware vLLM scheduler
After=graphical-session.target network.target

[Service]
Type=simple
WorkingDirectory=@ROOT_DIR@
ExecStart=/usr/bin/env bash @ROOT_DIR@/scripts/run_daemon.sh
Restart=on-failure
RestartSec=3
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
