[Unit]
Description=PLLM desktop overlay
After=graphical-session.target pllm-daemon.service
PartOf=graphical-session.target

[Service]
Type=simple
WorkingDirectory=@ROOT_DIR@
ExecStart=@HOME@/anaconda3/envs/pllm/bin/python -m pllm.desktop
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target

