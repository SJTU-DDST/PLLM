[Unit]
Description=PLLM desktop overlay
After=graphical-session.target pllm-daemon.service
PartOf=graphical-session.target

[Service]
Type=simple
WorkingDirectory=@ROOT_DIR@
ExecStart=/usr/bin/env bash @ROOT_DIR@/scripts/run_desktop.sh
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
